# Copy this file to .env and fill in your values:
#   cp .env.example .env

# Anthropic API key for AI word generation
ANTHROPIC_API_KEY=sk-ant-xxxxx

# Google OAuth Client ID (from Google Cloud Console → Credentials)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# Gmail SMTP (use a Google App Password: https://myaccount.google.com/apppasswords)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=xxxx xxxx xxxx xxxx
MAIL_SMTP_AUTH=true
MAIL_SMTP_STARTTLS=true

# Frontend (Vite only exposes VITE_ prefixed vars to the browser)
VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
